# Porta do servidor
PORT=8080
NODE_ENV=development

# Postgres (docker-compose up -d db)
DATABASE_URL=postgresql://kolibri:kolibri@localhost:5432/kolibri?schema=public

# Auth
JWT_SECRET=troque-isto-por-no-minimo-32-caracteres-aleatorios
# Domínio usado no SIWS (deve casar com a origem do front)
APP_DOMAIN=localhost:5173

# Solana
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
# Preencher após `anchor deploy` (Fase 1)
PROGRAM_ID=
# Keypair de serviço (server-custody) que ancora as txs — NUNCA commitar
SERVICE_KEYPAIR_PATH=.keys/service-keypair.json

# Base pública do passaporte (vai no metadata do NFT e no QR)
PUBLIC_PASSPORT_BASE_URL=http://localhost:5173/passport

# Storage local (MVP)
UPLOAD_DIR=uploads
